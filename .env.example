# Existing Docker network used by your n8n container.
# Find with:
# docker ps --format 'table {{.Names}}\t{{.Image}}\t{{.Networks}}'
N8N_NETWORK=n8n_default

# Existing n8n container name.
# Find with:
# docker ps --format 'table {{.Names}}\t{{.Image}}'
N8N_CONTAINER=n8n

# Production webhook path from the active n8n Webhook node.
# Include the leading /webhook/ segment.
N8N_WEBHOOK_PATH=/webhook/claw-inbound-REPLACE_WITH_RANDOM_VALUE

# Comma-separated sender allowlist in E.164 format.
# Example UK mobile format: +447700900000
ALLOWED_SENDERS=+447700900000

# Keep false unless you deliberately want group messages forwarded.
ALLOW_GROUPS=false

# Optional overrides.
# HEARTBEAT_INTERVAL_MS=25000
# HEARTBEAT_TIMEOUT_MS=75000
# WEBHOOK_TIMEOUT_MS=10000
# MAX_EVENT_BYTES=1048576
# MAX_RECENT_IDS=2000
